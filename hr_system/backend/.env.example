# Application Settings
APP_NAME="HR Management System"
APP_VERSION="1.0.0"
DEBUG=true

# Security
SECRET_KEY="your-super-secret-key-change-in-production-environment"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration
MONGODB_URL="mongodb://localhost:27017/hr_system"
DATABASE_NAME="hr_system"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="hr-system-documents"

# Cloudinary Configuration (Alternative to S3)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Email Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="noreply@hrsystem.com"

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000", "https://hrms.agpkacademy.in"]

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=["application/pdf", "image/jpeg", "image/png", "application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"]

# Payroll Settings
WORKING_DAYS_PER_MONTH=22
OVERTIME_RATE=1.5

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Monitoring
SENTRY_DSN="your-sentry-dsn"
